{
  "appId": "com.megan.apps",
  "appName": "Megan Apps",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "cleartext": true,
    "allowNavigation": [
      "appapi.megan.qzz.io",
      "megan.qzz.io",
      "*.megan.qzz.io"
    ]
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0a0a0f",
      "showSpinner": true,
      "spinnerColor": "#6366f1"
    },
    "StatusBar": {
      "style": "dark",
      "backgroundColor": "#0a0a0f"
    },
    "Browser": {
      "presentationStyle": "fullscreen"
    },
    "GoogleAuth": {
      "scopes": ["profile", "email"],
      "serverClientId": "599593422056-f4lpouihf09j8r33ibd6b6n8u9oqo81f.apps.googleusercontent.com",
      "forceCodeForRefreshToken": true,
      "androidClientId": "599593422056-f4lpouihf09j8r33ibd6b6n8u9oqo81f.apps.googleusercontent.com"
    }
  }
}
